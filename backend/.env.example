# Cadena de conexión SQL Server (ver docs/DATABASE.md)
DATABASE_URL=mssql+pyodbc://usuario:contraseña@servidor/nombre_bd?driver=ODBC+Driver+17+for+SQL+Server

# Clave secreta para JWT (generar una cadena aleatoria larga en producción)
SECRET_KEY=cambia-esto-por-una-clave-secreta-muy-larga
ACCESS_TOKEN_EXPIRE_MINUTES=480
